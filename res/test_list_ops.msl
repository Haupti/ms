$include "util_assertions.msl"
tests_start("LIST")

; range
let l1 = range(0, 5)
assert_eq(str(l1), "list(0,1,2,3,4)", "range(0, 5)")

; list_contains
assert_true(list_contains(l1, 2), "list_contains(l1, 2)")
assert_false(list_contains(l1, 5), "list_contains(l1, 5)")

; list_slice
let l2 = list_slice(l1, 1, 4)
assert_eq(str(l2), "list(1,2,3)", "list_slice(l1, 1, 4)")

; copy
let l2 = copy(l1)
assert_eq(str(l2), "list(0,1,2,3,4)", "list copy")

; list_remove
let l3 = list(10, 20, 30, 40)
list_remove(l3, 1)
assert_eq(str(l3), "list(10,30,40)", "list_remove(l3, 1)")
list_remove(l3, 0)
assert_eq(str(l3), "list(30,40)", "list_remove(l3, 0)")
list_remove(l3, 1)
assert_eq(str(l3), "list(30)", "list_remove(l3, 1)")

tests_success("LIST")
