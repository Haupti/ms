$include "util_assertions.msl"
tests_start("FUNCTIONS")
let x = 1;
function print_x() {
    print(x)
}

print_x()

function sub(a,b){
    print(str(a) <> " - " <> str(b) <> " = " <> str(a - b))
}

sub(5,12)
5.sub(12)
5 | sub(12)

function will_fail() {
  return error("failed")
}

function might_fail(a) { 
    if([a > 5] and [a < 20]){
        try will_fail()
        return #ok
    } else {
      return none
    }
}


print(might_fail(200))
print(might_fail(10))
print(might_fail(0))
tests_success("FUNCTIONS")
