let x = 1;
function print_x() {
    print(x)
}

print_x()

function sub(a,b){
    print(str(a) <> " - " <> str(b) <> " = " <> str(a - b))
}

sub(5,12)
5.sub(12)
5 | sub(12)

function will_fail() {
  return error("failed")
}

function might_fail(a) { 
    if([a > 5] and [a < 20]){
        return try will_fail()
    } elif (a < 5) {
        return expect will_fail()
    } else {
      return none
    }
}


print(might_fail(200))
print(might_fail(10))
print(might_fail(0))
