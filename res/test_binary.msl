$include "util_assertions.msl"
tests_start("NUMBER FORMATS AND BIT MANIPULATION")

assert_eq(bit_and(5, 3), 1, "bit_and(5, 3)")
assert_eq(bit_or(5, 3), 7, "bit_or(5, 3)")
assert_eq(bit_xor(5, 3), 6, "bit_xor(5, 3)")
assert_eq(bit_shift_left(1, 3), 8, "bit_shift_left(1, 3)")
assert_eq(bit_shift_right(8, 2), 2, "bit_shift_right(8, 2)")

; Hex tests
assert_eq(hex_encode(255), "ff", "hex_encode(255)")
assert_eq(hex_encode(0), "0", "hex_encode(0)")
assert_eq(hex_encode(16), "10", "hex_encode(16)")

assert_eq(hex_decode("ff"), 255, "hex_decode('ff')")
assert_eq(hex_decode("0"), 0, "hex_decode('0')")
assert_eq(hex_decode("10"), 16, "hex_decode('10')")

; Binary tests
assert_eq(binary_encode(255), "11111111", "binary_encode(255)")
assert_eq(binary_encode(0), "0", "binary_encode(0)")
assert_eq(binary_encode(10), "1010", "binary_encode(10)")

assert_eq(binary_decode("11111111"), 255, "binary_decode('11111111')")
assert_eq(binary_decode("0"), 0, "binary_decode('0')")
assert_eq(binary_decode("1010"), 10, "binary_decode('1010')")

tests_success("NUMBER FORMATS AND BIT MANIPULATION")
