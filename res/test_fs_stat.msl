$include "util_assertions.msl"
tests_start("FILESYSTEM STATS")

let test_file = "test_stat_file.txt"
fs_write(test_file, "hello stat")

let s = fs_stat(test_file)
assert_eq(s.at(#type), #file, "type should be #file")
assert_eq(s.at(#size), 10, "size should be 10")
assert_true(s.at(#last_write) > 0, "mtime should be > 0")

let s_dir = fs_stat("src")
assert_eq(s_dir.at(#type), #directory, "type should be #directory")

let s_none = fs_stat("non_existent_file_xyz")
assert_eq(str(s_none), "error(no such file or directory)", "should be an error")

fs_rm(test_file)
tests_success("FILESYSTEM STATS")
